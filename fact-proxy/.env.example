PORT=3000
OPENAI_API_KEY=replace-with-openai-key
MOTOGUIDE_PROXY_TOKEN=dev-token
OPENAI_MODEL=gpt-4o-mini
RATE_LIMIT_PER_MINUTE=30
MOTOGUIDE_DEVICE_BINDING_REQUIRED=false
MOTOGUIDE_TRUSTED_DEVICE_IDS=
MOTOGUIDE_PROMPT_OVERRIDES_ENABLED=false
MOTOGUIDE_PROMPT_OVERRIDES_OBJECT_URL=https://object-store-endpoint/prompt-overrides.json
MOTOGUIDE_PROMPT_OVERRIDES_REFRESH_SECONDS=60
MOTOGUIDE_PROMPT_OVERRIDES_HOST_ALLOWLIST=
MOTOGUIDE_PROMPT_OVERRIDES_AUTH_TOKEN=optional-token
